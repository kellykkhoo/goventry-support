# Copy to .env and fill in. Everything has a dev-safe fallback except the AI key.

# Database (SQLite locally; swap to a postgres:// URL at deploy time)
DATABASE_URL="file:./dev.db"

# Claude API key for the triage agent — console.anthropic.com
ANTHROPIC_API_KEY=""

# --- Email (outbound replies) ---
# Provider auto-selected: Microsoft 365 > Postman > Resend > dev mode (console log).

EMAIL_FROM="GovEntry Support <GovEntry_Support@tech.gov.sg>"
EMAIL_REPLY_TO="GovEntry_Support@tech.gov.sg"

# Microsoft 365 / Graph — send AS the support mailbox (true gov sender).
# IT provides these (Azure app registration + Mail.Send app permission).
MS_TENANT_ID=""
MS_CLIENT_ID=""
MS_CLIENT_SECRET=""
MS_SENDER_MAILBOX="GovEntry_Support@tech.gov.sg"

# Postman.gov.sg — gov sender; programmatic API needs approval.
POSTMAN_API_KEY=""
POSTMAN_FROM=""

# Resend — prototype fallback; can't truly send from a gov domain.
RESEND_API_KEY=""

# --- GitLab repos as triage knowledge source (off until all three are set) ---
GITLAB_URL=""              # e.g. https://gitlab.gov.sg (no trailing slash)
GITLAB_TOKEN=""            # read-only token: read_api / read_repository
GITLAB_PROJECTS=""         # comma-separated project paths or ids

# --- FormSG webhook (Storage mode form) ---
# Secret key from the FormSG form admin dashboard (download on form creation)
FORMSG_SECRET_KEY=""
# The exact public URL FormSG POSTs to — must match what you set in FormSG Settings -> Webhooks
FORMSG_WEBHOOK_URI="https://your-public-domain.example/api/webhooks/formsg"

# --- GovEntry registration webhook ---
# Shared secret used to verify X-GovEntry-Signature (HMAC-SHA512, v1 scheme).
# If empty, signature verification is SKIPPED (dev mode only — never in production).
GOVENTRY_WEBHOOK_SECRET=""
