FROM node:22-alpine
WORKDIR /app
COPY package.json package-lock.json* ./
RUN if [ -f package-lock.json ]; then npm ci --ignore-scripts 2>/dev/null || { echo "package-lock.json out of sync, regenerating..."; rm -f package-lock.json; npm install --ignore-scripts 2>/dev/null || npm install --legacy-peer-deps --ignore-scripts; }; else npm install --ignore-scripts 2>/dev/null || npm install --legacy-peer-deps --ignore-scripts; fi
COPY . .
RUN npm rebuild 2>/dev/null || true && \
    if grep -q '"postinstall"' package.json; then npm run postinstall; fi

# VIPER Agent — copied from build context (committed alongside this Dockerfile
# by getCloudModeFiles in lib/services/template-files.ts). Single source of
# truth lives in templates/viper-agent/ in the beta-rabbitdeploy repo.
# `COPY . .` above also copies viper-agent/ into /app — remove that duplicate
# so the user's file tree stays clean.
COPY viper-agent/ /viper-agent/
RUN chmod +x /viper-agent/entrypoint.sh && rm -rf /app/viper-agent

# Run as non-root user for container security
RUN addgroup -g 1001 -S viper && \
    adduser -S -u 1001 -G viper viper && \
    chown -R viper:viper /app /viper-agent

ENV NODE_OPTIONS="--max-old-space-size=384"
ENV VIPER_APP_PORT=3001
ENV VIPER_AGENT_PORT=9111
ENV PORT=3000
EXPOSE 3000

USER viper

ENTRYPOINT ["/viper-agent/entrypoint.sh"]
CMD []
